@startuml c4-context
title Digital Therapy Assistant - C4 Level 1 System Context

skinparam shadowing false
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam packageStyle rectangle
skinparam wrapWidth 220
skinparam maxMessageSize 220
skinparam rectangle {
  RoundCorner 12
  BorderColor #2F4858
}
skinparam node {
  RoundCorner 12
  BorderColor #2F4858
}
skinparam cloud {
  BorderColor #2F4858
}
skinparam database {
  BorderColor #2F4858
}

rectangle "Patients\n<<Person>>\nPrimary users seeking burnout recovery,\nCBT guidance, journaling, and crisis support" as patient #F6D55C
rectangle "Therapists / Doctors\n<<Person>>\nReview progress and support patient care" as therapist #F6D55C
rectangle "System Administrators\n<<Person>>\nManage platform operation and access" as admin #F6D55C
rectangle "AI Client\n<<External User Agent>>\nClaude Desktop or Claude Code using\nModel Context Protocol (MCP)" as ai_client #F6D55C

rectangle "Digital Therapy Assistant\n<<Software System>>\nReact/Nginx frontend, Spring Boot backend,\nMCP stdio tools, H2 persistence, and RAG vector store\nfor CBT workflows and crisis support" as dta #5DADE2

cloud "Anthropic API\n<<External System>>\nLLM service used by AI clients\nand configured assistant workflows" as anthropic #D6EAF8
cloud "LLM Provider\n<<External System>>\nOpenAI-compatible API for therapeutic\nresponse generation and analysis" as llm #D6EAF8
cloud "Email Service\n<<External System>>\nNotification and reminder delivery" as email #D6EAF8
cloud "Healthcare EHR Systems\n<<External System>>\nFHIR-based export target for clinical interoperability" as ehr #D6EAF8

rectangle "GitHub\n<<External System>>\nSource repository and GitHub Actions\nCI/CD/CD automation" as github #D6EAF8
database "GitHub Container Registry\n<<External System>>\nStores versioned frontend and backend\nDocker images" as ghcr #D6EAF8
node "AWS EC2\n<<Cloud Deployment Target>>\nProduction host running Docker Compose\nwith Elastic IP access" as ec2 #D5F5E3

patient -down-> dta : Uses web UI on port 3000\nfor sessions, diaries, insights,\nand crisis help
therapist -down-> dta : Reviews progress and supports patient workflows
admin -down-> dta : Maintains users, security,\ndeployment, and platform settings
ai_client -down-> dta : Connects via MCP stdio tools\nfor assistant-driven workflows
ai_client -right-> anthropic : Sends model requests

dta -right-> llm : Sends prompts and receives AI responses,\ndistortion analysis, reframing prompts,\nand crisis assessment
dta -right-> email : Sends reminders and notifications
dta -right-> ehr : Exports progress or treatment data via FHIR

github -down-> ghcr : Publishes Docker images after\nbuild and smoke-test gates
github -down-> ec2 : Deploys approved images via\nGitHub Actions and SSH
ghcr -down-> ec2 : EC2 pulls frontend and backend images
ec2 -up-> dta : Hosts deployed application stack

legend right
|= Notation |= Meaning |
| <back:#F6D55C>Person / User Agent</back> | Human user or AI client actor |
| <back:#5DADE2>Software System</back> | System being modeled |
| <back:#D6EAF8>External System</back> | External dependency, source, registry, or automation platform |
| <back:#D5F5E3>Deployment Target</back> | Cloud runtime environment |
| Solid arrow | Relationship with labeled interaction |
endlegend

@enduml
